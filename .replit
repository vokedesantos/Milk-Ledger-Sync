modules = ["nodejs-20"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "install"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[nix]
channel = "stable-25_05"

[[ports]]
localPort = 8080
externalPort = 8080
